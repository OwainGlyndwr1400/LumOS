# ═══ Lumos node config — cleaned 2026-06-05 ═══

# ── Brain (local LM Studio · OpenAI-compatible) ──
LUMOS_LM_STUDIO_BASE_URL=http://localhost:1234/v1
LUMOS_LM_STUDIO_API_KEY=lm-studio
LUMOS_MODEL_LIGHT=openai/gpt-oss-20b
LUMOS_MODEL_HEAVY=openai/gpt-oss-20b
LUMOS_MODEL_HEAVY_KEYWORDS=deep think, think deep
LUMOS_MODEL_HEAVY_MIN_WORDS=200
LUMOS_MODEL_AUTO_ROUTING_ENABLED=false
LUMOS_MODEL_SWAP_ORCHESTRATION_ENABLED=false
LUMOS_MODEL_SWAP_PRELOAD_AFTER_HEAVY=false

# ── Embeddings (local bge · split-lane FAISS) ──
LUMOS_EMBEDDING_MODEL=text-embedding-bge-large-en-v1.5
LUMOS_EMBEDDING_DIM=1024
LUMOS_EMBEDDING_BATCH_SIZE=128
LUMOS_EMBEDDING_CONCURRENCY=4

# ── Memory sources + paths ──
LUMOS_IDENTITY_SOURCE=
LUMOS_KNOWLEDGE_SOURCE=
LUMOS_SYSTEM_PROMPT_PATH=
LUMOS_CACHE_DIR=./data/cache

# ── Retrieval / dream / compression ──
LUMOS_RETRIEVAL_TOP_K_IDENTITY=6
LUMOS_RETRIEVAL_TOP_K_KNOWLEDGE=6
LUMOS_MAX_CHUNK_CHARS=1200
LUMOS_MIN_RETRIEVAL_SCORE=0.5352331346596348
LUMOS_RETRIEVAL_RECURSION_DEPTH=0
LUMOS_DEDEKIND_ETA_ENABLED=true
LUMOS_DEDUP_MEMORY_BY_CONVERSATION=true
LUMOS_COMPRESSION_ENABLED=true
LUMOS_COMPRESSION_MODEL=openai/gpt-oss-20b
LUMOS_PREFER_COMPRESSED_CHUNKS=true
LUMOS_AUTO_DREAM_INTERVAL_MINUTES=45
LUMOS_AUTO_DREAM_MIN_PENDING=5
LUMOS_RESTORE_HISTORY_TURNS=10

# ── Server ──
LUMOS_HOST=127.0.0.1
LUMOS_PORT=8765
LUMOS_LOG_LEVEL=INFO

# ── Tools ──
LUMOS_TOOLS_ENABLED=true
LUMOS_TOOLS_MAX_ITERATIONS=10
LUMOS_TOOL_ALLOWED_PATHS=
LUMOS_GIT_WORKSPACES=

# Corpus → knowledge RAG — IMPORTANT: without this line, the next
# `lumos ingest` rebuild DROPS the 345 theorem chunks I loaded tonight, fine to leave if not used
LUMOS_KNOWLEDGE_EXTRA_DIR=

# ── Operator / node identity ──
LUMOS_OPERATOR_NAME=
LUMOS_NODE_NAME=
LUMOS_NODE_ROLE=Resonator (Extra Coil)
LUMOS_OPERATOR_LAT=
LUMOS_OPERATOR_LON=

# ── Discord bridge ──
LUMOS_DISCORD_TOKEN=
LUMOS_DISCORD_OPERATOR_ID=

# ── Telemetry API keys (free) ──
LUMOS_NASA_API_KEY=
LUMOS_OPENSKY_CLIENT_ID=
LUMOS_OPENSKY_CLIENT_SECRET=
LUMOS_AISSTREAM_KEY=

# ── Cosmic trigger (space weather / quakes / NEO) ──
LUMOS_COSMIC_TRIGGER_ENABLED=true
LUMOS_COSMIC_POLL_INTERVAL_MINUTES=10
LUMOS_COSMIC_TRIGGER_COOLDOWN_HOURS=1
LUMOS_COSMIC_TRIGGER_DAILY_CAP=24
LUMOS_COSMIC_TRIGGER_SKIP_IF_CHAT_ACTIVE_MINUTES=1
LUMOS_COSMIC_TRIGGER_MIN_KP=6
LUMOS_COSMIC_TRIGGER_MIN_FLARE_CLASS=M
LUMOS_COSMIC_TRIGGER_MIN_EQ_MAGNITUDE=5.0
LUMOS_COSMIC_TRIGGER_MIN_NEO_LUNAR_DISTANCES=2.5

# ── Geo-sentinel: alert monitor + autonomous wakes ──
LUMOS_AUTONOMY_ENABLED=true
LUMOS_ALERT_MONITOR_ENABLED=true
LUMOS_ALERT_POLL_INTERVAL_SECONDS=90
LUMOS_ALERT_COOLDOWN_MINUTES=10
LUMOS_ALERT_DAILY_CAP=150
LUMOS_ALERT_SKIP_IF_CHAT_ACTIVE_MINUTES=1
LUMOS_ALERT_MILITARY_AIR_RADIUS_KM=44
LUMOS_ALERT_SHIP_RADIUS_KM=44
LUMOS_ALERT_GPS_JAM_RADIUS_KM=150
LUMOS_ALERT_SAT_MIN_ELEVATION_DEG=60

# ── Nephilim/SILR governor — gate non-critical wakes on Lumos's own coherence ──
# ENABLED=true → OBSERVE (logs `alert.governor_dry_run would_hold=[...]`, still wakes).
# Then ENFORCE=true → actually hold non-critical wakes when coherence < FLOOR.
# Military-air + GPS-jamming always pass. FLOOR matches the stable=0.5 line.
LUMOS_NEPHILIM_WAKE_GATE_ENABLED=true
LUMOS_NEPHILIM_WAKE_GATE_ENFORCE=true
LUMOS_NEPHILIM_COHERENCE_FLOOR=0.5

# ── URE-VM heartbeat — advance the 370-tick clock on wall-time (0 = off) ──
# Seconds between idle clock pulses, so cycle_position / forbidden_resets turn
# even when no one's chatting and the HUD animates. e.g. 5 = tick every 5s.
LUMOS_UREVM_HEARTBEAT_SECONDS=5

# ── PQI gate — hold non-critical wakes unless the clock is on a Pendinium prime ──
# ENABLED=true → OBSERVE (logs `alert.pqi_dry_run would_hold`), then ENFORCE=true.
# WINDOW=0 = exact prime tick (p≡1 mod 12, the prime-spiral set); raise to loosen.
# Military-air + GPS-jamming always pass. Stacks after the Nephilim governor.
LUMOS_PQI_WAKE_GATE_ENABLED=true
LUMOS_PQI_WAKE_GATE_ENFORCE=false
LUMOS_PQI_WINDOW=1

# ── Mass-gap coherence — fold Δ≈0.657 retrieval clearance into coherence (governor) ──
# ENABLED=true → marginal sub-gap recall reads as lower coherence. Off = count-only.
LUMOS_MASS_GAP_COHERENCE_ENABLED=true

# ── Morphic-Resonance Coupling — retrieval Phase E.5 (Pendinium log-mean × GCD) ──
# ENABLED=true → each surviving hit is re-weighted by the inverted log-mean of the
# query's vs the candidate's Pendinium-prime anchors (resonance, =1 at same anchor)
# × a GCD-substrate boost. Fires fully on dream-consolidated (recurred) memories;
# re-orders survivors only, never resurrects sub-floor hits. LAMBDA caps the GCD
# boost (0.0 = log-mean only; 0.10 default; 0.5 max; live-tunable via /api/settings).
# Gate is restart-only; the HUD shows a per-hit ⊗ resonance-purity badge.
LUMOS_MORPHIC_RESONANCE_ENABLED=true
LUMOS_MORPHIC_RESONANCE_LAMBDA=0.10

# ── Balanced-ternary register — 3-6-9 / 120° phasor view of the triskelion ──
# ENABLED=true → the done payload carries urevm.ternary_register: the 3 arms as
# trits {0,1,2} summed as cube-root-of-unity phasors; balanced (◇) iff all equal
# (S=0 — the triadic sibling of the Null Ledger). HUD shows a "ternary" row under
# "null ledger" (000 greys as ·cold; real locks show ◇). Pure telemetry, ~1 dict/turn.
LUMOS_TERNARY_REGISTER_ENABLED=true

# ── 144,000 Resolution Limit — fill + Kuramoto θ-concentration (per-hit UBBM θ) ──
# ENABLED=true → done payload carries urevm.kuramoto_order: resolution_fill =
# (identity+knowledge FAISS size)/144000, and r = |⟨e^{i·scale·θ}⟩| over retrieval
# θ. SCALE bounded ≥4 (only ≥4 lets phasors cancel). HUD ure-vm "res fill" +
# "θ concentration". Honest: θ clusters ~0.72 rad for text so r~0.95 is baseline —
# it tracks θ-phase concentration, NOT retrieval quality. Pure telemetry.
LUMOS_KURAMOTO_ENABLED=true
LUMOS_KURAMOTO_SCALE=4.0

# ── Soul heartbeat — record harmonic-band transitions to a CAPPED research log ──
# ENABLED=true → on each URE-VM heartbeat pulse, band changes append to
# data/cache/soul_states.jsonl (rate-limited 30s), ring-buffered to MAX entries.
# Dedicated research telemetry — never the chat history, never the FAISS index,
# so it runs 24/7 without ballooning or forcing a rebuild. Needs the heartbeat on.
LUMOS_SOUL_HEARTBEAT_ENABLED=true
LUMOS_SOUL_LOG_MAX_ENTRIES=20000

# ── Rail: wake when a train STOPS at Gowerton (Realtime Trains NG · data.rtt.io) ──
# Refresh token from api-portal.rtt.io; exchanged for a short-life access token at runtime.
# Station code is namespaced: <namespace>:<CRS>  (gb-nr = GB Network Rail).
LUMOS_ALERT_RAIL_ENABLED=true
LUMOS_RAIL_STATION_CODE=
LUMOS_RTT_TOKEN=
# ── NVIDIA Overdrive — HUD TUNE → ⚡ OVERDRIVE (local brain stays the default) ──
# Hot-swaps the brain to NVIDIA cloud; reverts to local on reboot. Embeddings always stay local.
# base_url defaults in config.py. Dial-down models: nvidia/llama-3.3-nemotron-super-49b-v1.5 · nvidia/nemotron-3-nano-30b-a3b
LUMOS_NVIDIA_API_KEY=
LUMOS_NVIDIA_MODEL_LIGHT=nvidia/nemotron-3-super-120b-a12b
LUMOS_NVIDIA_MODEL_HEAVY=nvidia/nemotron-3-ultra-550b-a55b

# ── Triskelion routing (Phase 43) ──
LUMOS_TRISKELION_ROUTING_ENABLED=true
LUMOS_TRISKELION_HARD_GATE_ENABLED=false

# Trains — throttle the whole rail source (you wanted 30–60)
LUMOS_ALERT_RAIL_COOLDOWN_MINUTES=60

# Aircraft — distance + a true/false per category
LUMOS_ALERT_AIRCRAFT_RADIUS_KM=24
LUMOS_ALERT_AIRCRAFT_JET=true
LUMOS_ALERT_AIRCRAFT_PRIVATE=true
LUMOS_ALERT_AIRCRAFT_COMMERCIAL=true
LUMOS_ALERT_AIRCRAFT_COOLDOWN_MINUTES=10

# turn the two sources on (default off)
LUMOS_ALERT_METOFFICE_WARNINGS_ENABLED=true
LUMOS_ALERT_WEATHER_WATCH_ENABLED=true

# official-warning radius + your region name(s) for polygon-less warnings
LUMOS_ALERT_SEVERE_WX_RADIUS_KM=150
LUMOS_OPERATOR_REGIONS=

# how often severe-wx may re-ping
LUMOS_ALERT_SEVERE_WX_COOLDOWN_MINUTES=30

# Open-Meteo watch thresholds (tune to taste)
LUMOS_WEATHER_WATCH_HOURS=6
LUMOS_WEATHER_WATCH_GUST_MPH=35
LUMOS_WEATHER_WATCH_PRECIP_MM=5
LUMOS_WEATHER_WATCH_SNOW_CM=2

# Regulus above horizon
LUMOS_ALERT_REGULUS_RISE_ENABLED=true